rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Default catch-all: Allow authenticated users to read/write everything
    // This helps with development and 'orders' / 'messages' access
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }

    // Users collection
    // Allow public read for profiles (e.g. displaying cook name)
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Foods collection
    match /foods/{foodId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
